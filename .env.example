# --- Site (OAuth redirect & proposal links) ---
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# --- Session signing (min 16 characters) ---
AUTH_SECRET=replace-with-long-random-secret

# --- Neon Postgres (console.neon.tech) ---
# У Vercel: підключи інтеграцію Neon або встав скопійований connection string з Neon Dashboard.
# Формат: postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

# --- Discord OAuth2 (https://discord.com/developers/applications) ---
# У Discord → OAuth2 → Redirects додай URL для КОЖНОГО домену, з якого заходять
# (наприклад і vercel.app, і свій домен): https://домен/api/auth/discord/callback
# Логін тепер використовує хост з браузера, тому redirect має збігатися з тим, що в адресному рядку.
DISCORD_CLIENT_ID=
# Опційно замість DISCORD_CLIENT_ID (той самий Application ID, зручно на Vercel):
# NEXT_PUBLIC_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Сповіщення про пропозиції (Discord webhook + Telegram — той самий події) ---
# Розпочато голосування при створенні; результати — коли термін вийшов або автор закрив достроково.
# Telegram: створи бота через @BotFather, додай у канал/групу, chat_id — @userinfobot або getUpdates
# Telegram: обовʼязково TELEGRAM_MESSAGE_THREAD_ID (id теми) — без нього бот нічого не надсилає
# Як дізнатись topic id: надішли повідомлення в потрібну гілку → getUpdates у бота або @RawDataBot
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=

# --- Optional: Vercel Cron → POST /api/cron/close-proposals ---
# Header: Authorization: Bearer {CRON_SECRET}
CRON_SECRET=
